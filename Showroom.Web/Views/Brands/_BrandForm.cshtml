@model Showroom.Web.Models.BrandFormViewModel

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Hãng xe</span>
            <h1>@ViewData["PageTitle"]</h1>
            <p>@ViewData["PageDescription"]</p>
        </div>
    </div>

    <article class="panel-card form-panel">
        <form asp-action="@ViewData["FormAction"]" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Toyota, Hyundai..." />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="page-actions">
                <button type="submit" class="btn btn-primary">@ViewData["SubmitText"]</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
            </div>
        </form>
    </article>
</section>
