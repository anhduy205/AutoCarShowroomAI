@model IReadOnlyList<Showroom.Web.Models.OrderListItemViewModel>

@{
    ViewData["Title"] = "Quan ly don hang";
    var statusMessage = TempData["StatusMessage"] as string;
    var statusType = TempData["StatusType"] as string ?? "success";
}

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Giao dich</span>
            <h1>Quan ly don hang</h1>
            <p>Tao, cap nhat va theo doi cac don hang phat sinh de du lieu ban hang luon dong bo voi thong ke showroom.</p>
        </div>
        <div class="page-actions">
            <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Index">Ve bang dieu khien</a>
            <a class="btn btn-primary" asp-action="Create">Tao don hang</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-banner status-@statusType">
            @statusMessage
        </div>
    }

    <article class="panel-card">
        @if (Model.Count == 0)
        {
            <p class="empty-state mb-0">Hien chua co don hang nao. Ban co the tao don hang dau tien ngay bay gio.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Ma don</th>
                            <th>Khach hang</th>
                            <th>Trang thai</th>
                            <th class="text-end">Tong xe</th>
                            <th class="text-end">Tong tien</th>
                            <th class="text-end">Ngay tao</th>
                            <th class="text-end">Thao tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusClass = item.Status switch
                            {
                                OrderStatusCatalog.Paid or OrderStatusCatalog.Completed or OrderStatusCatalog.Delivered => "status-success",
                                OrderStatusCatalog.Cancelled => "status-danger",
                                _ => "status-warning"
                            };

                            <tr>
                                <td>#@item.Id</td>
                                <td>@item.CustomerName</td>
                                <td>
                                    <span class="status-chip @statusClass">@item.Status</span>
                                </td>
                                <td class="text-end">@item.TotalQuantity</td>
                                <td class="text-end">@item.TotalAmount.ToString("N0") VNĐ</td>
                                <td class="text-end">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <div class="table-actions">
                                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Sua</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline-form" onsubmit="return confirm('Ban co chac muon xoa don hang nay?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xoa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>
