@model IReadOnlyList<Showroom.Web.Models.OrderListItemViewModel>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    var statusMessage = TempData["StatusMessage"] as string;
    var statusType = TempData["StatusType"] as string ?? "success";
}

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Giao dịch</span>
            <h1>Quản lý đơn hàng</h1>
            <p>Tạo, cập nhật và theo dõi các đơn hàng phát sinh để dữ liệu bán hàng luôn đồng bộ với thống kê showroom.</p>
        </div>
        <div class="page-actions">
            <a class="btn btn-outline-secondary" asp-controller="Admin" asp-action="Index">Về bảng điều khiển</a>
            <a class="btn btn-primary" asp-action="Create">Tạo đơn hàng</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-banner status-@statusType">
            @statusMessage
        </div>
    }

    <article class="panel-card">
        @if (Model.Count == 0)
        {
            <p class="empty-state mb-0">Hiện chưa có đơn hàng nào. Bạn có thể tạo đơn hàng đầu tiên ngay bây giờ.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Tổng xe</th>
                            <th class="text-end">Tổng tiền</th>
                            <th class="text-end">Ngày tạo</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusClass = item.Status switch
                            {
                                OrderStatusCatalog.Paid or OrderStatusCatalog.Completed or OrderStatusCatalog.Delivered => "status-success",
                                OrderStatusCatalog.Cancelled => "status-danger",
                                _ => "status-warning"
                            };

                            <tr>
                                <td>#@item.Id</td>
                                <td>@item.CustomerName</td>
                                <td>
                                    <span class="status-chip @statusClass">@item.Status</span>
                                </td>
                                <td class="text-end">@item.TotalQuantity</td>
                                <td class="text-end">@item.TotalAmount.ToString("N0") VNĐ</td>
                                <td class="text-end">@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td class="text-end">
                                    <div class="table-actions">
                                        <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Xem</a>
                                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline-form" onsubmit="return confirm('Bạn có chắc muốn xoá đơn hàng này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xoá</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>

