@model Showroom.Web.Models.FriendlyErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="dashboard-shell">
    <article class="panel-card">
        <h1 class="h3 mb-3">@Model.Title</h1>
        <p class="text-danger mb-4">@Model.Message</p>

        <div class="alert alert-secondary mb-4" role="alert">
            <div class="fw-semibold mb-1">Goi y xu ly</div>
            <div class="small">
                Neu day la loi lien quan database (thieu cot/bang), hay chay <code>database/upgrade.sql</code> (hoac <code>database/setup.sql</code>) de cap nhat schema.
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.RequestId))
        {
            <p class="mb-0">
                <strong>Ma yeu cau:</strong> <code>@Model.RequestId</code>
            </p>
        }
    </article>
</section>

