@model Showroom.Web.Models.CarDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
    var statusLabel = Model.Status switch
    {
        CarStatusCatalog.InStock => "Con hang",
        CarStatusCatalog.Promotion => "Khuyen mai",
        CarStatusCatalog.Sold => "Da ban",
        _ => Model.Status
    };
    var statusClass = Model.Status switch
    {
        CarStatusCatalog.InStock => "status-success",
        CarStatusCatalog.Promotion => "status-warning",
        CarStatusCatalog.Sold => "status-danger",
        _ => "status-warning"
    };
}

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Xe dang ban</span>
            <h1 class="mb-2">@Model.Name</h1>
            <p class="mb-0">@Model.BrandName · @(string.IsNullOrWhiteSpace(Model.Type) ? "-" : Model.Type) · @(Model.Year is null ? "-" : Model.Year.Value.ToString())</p>
        </div>
        <div class="page-actions">
            <a class="btn btn-outline-secondary" href="/cars">Quay lai danh sach</a>
            <button type="button"
                    class="btn btn-primary"
                    data-chatbot-open
                    data-chatbot-prefill="Toi dang xem xe @Model.BrandName @Model.Name (id @Model.Id). Hay tu van ly do nen chon xe nay va goi y 2 mau tuong tu trong showroom.">
                Hoi AI tu van
            </button>
        </div>
    </div>

    <article class="panel-card">
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="car-detail-hero @(Model.ImageUrls.Count == 0 ? "car-thumb-placeholder" : string.Empty)" data-car-hero>
                    @if (Model.ImageUrls.Count == 0)
                    {
                        <div class="car-thumb-placeholder">Chua co anh</div>
                    }
                    else
                    {
                        <img src="@Model.ImageUrls[0]" alt="Anh @Model.Name" data-car-hero-img loading="eager" />
                    }
                </div>

                @if (Model.ImageUrls.Count > 1)
                {
                    <div class="car-detail-gallery mt-3" data-car-gallery>
                        @foreach (var url in Model.ImageUrls)
                        {
                            <button type="button" class="car-thumb-button" data-car-thumb="@url" aria-label="Xem anh">
                                <img src="@url" alt="Anh @Model.Name" loading="lazy" />
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="col-lg-5">
                <div class="mb-2">
                    <span class="status-chip @statusClass">@statusLabel</span>
                </div>

                <div class="car-detail-price">@Model.Price.ToString("N0") VND</div>

                <div class="panel-card p-3 mb-3" style="border-radius: 22px;">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Mau</dt>
                        <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.Color) ? Model.Color : "-")</dd>

                        <dt class="col-sm-5">Ton kho</dt>
                        <dd class="col-sm-7">@Model.StockQuantity</dd>

                        <dt class="col-sm-5">Loai</dt>
                        <dd class="col-sm-7">@(string.IsNullOrWhiteSpace(Model.Type) ? "-" : Model.Type)</dd>

                        <dt class="col-sm-5">Nam</dt>
                        <dd class="col-sm-7">@((Model.Year is null) ? "-" : Model.Year.Value.ToString())</dd>
                    </dl>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <hr />
                    <h2 class="h5">Mo ta</h2>
                    <p class="mb-0">@Model.Description</p>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Specifications))
                {
                    <hr />
                    <h2 class="h5">Thong so ky thuat</h2>
                    <pre class="spec-block mb-0">@Model.Specifications</pre>
                }
            </div>
        </div>
    </article>
</section>

