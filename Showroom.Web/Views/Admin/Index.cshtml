@model Showroom.Web.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Bang dieu khien";
    var bannerClass = Model.IsDatabaseConnected ? "status-success" : "status-warning";
    var isAdministrator = User.IsInRole(ShowroomRoles.Administrator);
    var hasSalesFilter = Model.SalesFrom is not null || Model.SalesTo is not null;
}

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Bang dieu khien</span>
            <h1>Toan canh van hanh showroom</h1>
            <p>Theo doi nhanh ton kho, co cau thuong hieu va hieu qua ban hang trong cung mot khong gian.</p>
        </div>
        <div class="page-actions">
            <a class="btn btn-primary" asp-controller="Orders" asp-action="Index">Quan ly don hang</a>
            @if (isAdministrator)
            {
                <a class="btn btn-outline-secondary" asp-controller="Brands" asp-action="Index">Quan ly hang xe</a>
                <a class="btn btn-outline-secondary" asp-controller="Cars" asp-action="Index">Quan ly xe</a>
                <a class="btn btn-outline-secondary" asp-controller="AuditLogs" asp-action="Index">Xem nhat ky</a>
            }
        </div>
    </div>

    <div class="status-banner @bannerClass">
        <strong>Trang thai ket noi:</strong> @Model.StatusMessage
    </div>

    <article class="panel-card dashboard-filter-panel">
        <form method="get" asp-action="Index" class="dashboard-filter-form">
            <div class="dashboard-filter-copy">
                <h2 class="h4 mb-1">Loc thong ke xe ban chay</h2>
                <p class="table-note mb-0">Chon khoang ngay tao don hang de xem top xe ban chay trong giai doan mong muon.</p>
            </div>
            <div class="dashboard-filter-fields">
                <div>
                    <label class="form-label" for="salesFrom">Tu ngay</label>
                    <input class="form-control" id="salesFrom" name="salesFrom" type="date" value="@(Model.SalesFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div>
                    <label class="form-label" for="salesTo">Den ngay</label>
                    <input class="form-control" id="salesTo" name="salesTo" type="date" value="@(Model.SalesTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="dashboard-filter-actions">
                    <button type="submit" class="btn btn-primary">Ap dung</button>
                    @if (hasSalesFilter)
                    {
                        <a class="btn btn-outline-secondary" asp-action="Index">Xoa loc</a>
                    }
                </div>
            </div>
        </form>
    </article>

    <div class="metrics-grid">
        <article class="stat-card">
            <div class="stat-label">Tong so xe ton kho</div>
            <p class="stat-value">@Model.TotalCarsInStock</p>
        </article>
        <article class="stat-card">
            <div class="stat-label">So hang xe dang quan ly</div>
            <p class="stat-value">@Model.BrandInventory.Count</p>
        </article>
        <article class="stat-card">
            <div class="stat-label">Mau xe ban chay dang hien thi</div>
            <p class="stat-value">@Model.BestSellingCars.Count</p>
        </article>
    </div>

    <div class="dashboard-grid">
        <article class="panel-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 mb-1">Thong ke ton kho theo hang</h2>
                    <p class="table-note mb-0">Tong hop so luong xe hien con trong kho theo tung thuong hieu.</p>
                </div>
            </div>

            @if (Model.BrandInventory.Count == 0)
            {
                <p class="table-note mb-0">Hien chua co du lieu ton kho theo hang xe.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Hang xe</th>
                                <th class="text-end">So luong ton</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BrandInventory)
                            {
                                <tr>
                                    <td>@item.BrandName</td>
                                    <td class="text-end">@item.StockQuantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="panel-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 mb-1">Thong ke xe ban chay</h2>
                    <p class="table-note mb-0">
                        Cac mau xe noi bat dua tren nhung don hang da hoan tat, da thanh toan hoac da giao xe.
                        @if (hasSalesFilter)
                        {
                            <span>Khoang loc hien tai: @(Model.SalesFrom?.ToString("dd/MM/yyyy") ?? "tat ca") - @(Model.SalesTo?.ToString("dd/MM/yyyy") ?? "tat ca").</span>
                        }
                    </p>
                </div>
            </div>

            @if (Model.BestSellingCars.Count == 0)
            {
                <p class="table-note mb-0">Hien chua co du lieu thong ke ban hang trong khoang da chon.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Mau xe</th>
                                <th>Hang xe</th>
                                <th class="text-end">Da ban</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BestSellingCars)
                            {
                                <tr>
                                    <td>@item.CarName</td>
                                    <td>@item.BrandName</td>
                                    <td class="text-end">@item.SoldQuantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    </div>
</section>
