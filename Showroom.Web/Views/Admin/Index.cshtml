@model Showroom.Web.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Bang dieu khien";
    var bannerClass = Model.IsDatabaseConnected ? "status-success" : "status-warning";
    var isAdministrator = User.IsInRole(ShowroomRoles.Administrator);
}

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Bang dieu khien</span>
            <h1>Toan canh van hanh showroom</h1>
            <p>Theo doi nhanh tinh trang kho xe, co cau thuong hieu va hieu qua ban hang trong cung mot khong gian.</p>
        </div>
        <div class="page-actions">
            <a class="btn btn-primary" asp-controller="Orders" asp-action="Index">Quan ly don hang</a>
            @if (isAdministrator)
            {
                <a class="btn btn-outline-secondary" asp-controller="Brands" asp-action="Index">Quan ly hang xe</a>
                <a class="btn btn-outline-secondary" asp-controller="Cars" asp-action="Index">Quan ly xe</a>
                <a class="btn btn-outline-secondary" asp-controller="AuditLogs" asp-action="Index">Xem nhat ky</a>
            }
        </div>
    </div>

    <div class="status-banner @bannerClass">
        <strong>Trang thai ket noi:</strong> @Model.StatusMessage
    </div>

    <div class="metrics-grid">
        <article class="stat-card">
            <div class="stat-label">Tong so xe trong showroom</div>
            <p class="stat-value">@Model.TotalCars</p>
        </article>
        <article class="stat-card">
            <div class="stat-label">So hang xe dang quan ly</div>
            <p class="stat-value">@Model.BrandInventory.Count</p>
        </article>
        <article class="stat-card">
            <div class="stat-label">Mau xe ban chay dang hien thi</div>
            <p class="stat-value">@Model.BestSellingCars.Count</p>
        </article>
    </div>

    <div class="dashboard-grid">
        <article class="panel-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 mb-1">Thong ke so luong xe theo hang</h2>
                    <p class="table-note mb-0">Tong hop nhanh co cau san pham hien co trong showroom theo tung thuong hieu.</p>
                </div>
            </div>

            @if (Model.BrandInventory.Count == 0)
            {
                <p class="table-note mb-0">Hien chua co du lieu thong ke theo hang xe.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Hang xe</th>
                                <th class="text-end">So luong xe</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BrandInventory)
                            {
                                <tr>
                                    <td>@item.BrandName</td>
                                    <td class="text-end">@item.CarCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="panel-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 mb-1">Thong ke xe ban chay</h2>
                    <p class="table-note mb-0">Cac mau xe noi bat dua tren nhung don hang da hoan tat, da thanh toan hoac da giao xe.</p>
                </div>
            </div>

            @if (Model.BestSellingCars.Count == 0)
            {
                <p class="table-note mb-0">Hien chua co du lieu thong ke ban hang.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Mau xe</th>
                                <th>Hang xe</th>
                                <th class="text-end">Da ban</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BestSellingCars)
                            {
                                <tr>
                                    <td>@item.CarName</td>
                                    <td>@item.BrandName</td>
                                    <td class="text-end">@item.SoldQuantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    </div>
</section>
