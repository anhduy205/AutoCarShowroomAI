@{
    ViewData["Title"] = "Showroom xe sang";
}

<section class="hero-panel">
    <div class="hero-copy">
        <span class="eyebrow">Auto Car Showroom</span>
        <h1>Không gian xe sang dành cho phong cách sống đẳng cấp.</h1>
        <p>
            Khám phá showroom ô tô được thiết kế cho những khách hàng đề cao sự tinh tế,
            trải nghiệm tư vấn chuẩn mực và danh mục xe được tuyển chọn kỹ lưỡng từ nhiều thương hiệu uy tín.
        </p>

        <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="#vi-sao-chon">Khám phá showroom</a>
            <a class="btn btn-outline-light btn-lg" asp-controller="Admin" asp-action="Login">Đăng nhập quản trị</a>
        </div>

        <div class="hero-metrics">
            <article class="metric-chip">
                <strong>Danh mục chọn lọc</strong>
                <span>Nhiều dòng sedan, SUV và crossover cao cấp.</span>
            </article>
            <article class="metric-chip">
                <strong>Tư vấn chuyên nghiệp</strong>
                <span>Đồng hành từ trải nghiệm xe đến quyết định sở hữu.</span>
            </article>
        </div>
    </div>

    <div class="hero-card-grid">
        <article class="hero-card spotlight-card">
            <span class="card-tag">Ấn tượng đầu tiên</span>
            <h2>Không gian trưng bày tối giản, sang trọng và chuẩn cảm xúc xe sang.</h2>
            <p>Mỗi khu vực được thiết kế để tôn lên đường nét, vật liệu và cá tính riêng của từng mẫu xe.</p>
        </article>
        <article class="hero-card">
            <h2>Đa thương hiệu</h2>
            <p>Từ các mẫu xe phổ biến đến những lựa chọn nổi bật cho khách hàng tìm kiếm giá trị khác biệt.</p>
        </article>
        <article class="hero-card">
            <h2>Quản trị chặt chẽ</h2>
            <p>Hệ thống hỗ trợ thống kê, quản lý danh mục và bảo vệ khu vực quản trị an toàn.</p>
        </article>
    </div>
</section>

<section class="feature-grid" id="vi-sao-chon">
    <article class="feature-card">
        <span class="feature-index">01</span>
        <h3>Thiết kế đậm chất showroom cao cấp</h3>
        <p>Ngôn ngữ hình ảnh mạnh mẽ, ánh kim tinh tế và cảm giác sang trọng xuyên suốt từng điểm chạm.</p>
    </article>
    <article class="feature-card">
        <span class="feature-index">02</span>
        <h3>Danh mục xe rõ ràng, dễ theo dõi</h3>
        <p>Hãng xe, mẫu xe, giá bán và tồn kho được trình bày mạch lạc để hỗ trợ tư vấn hiệu quả hơn.</p>
    </article>
    <article class="feature-card">
        <span class="feature-index">03</span>
        <h3>Quản trị an toàn phía sau hậu trường</h3>
        <p>Khu quản trị riêng biệt giúp kiểm soát truy cập, cập nhật dữ liệu và theo dõi thống kê bán hàng.</p>
    </article>
</section>

<section class="collection-grid">
    <article class="collection-card featured">
        <span class="eyebrow">Trải nghiệm</span>
        <h3>Định vị không gian mua xe tinh tế</h3>
        <p>
            Auto Car Showroom được xây dựng để mang đến cảm giác chuyên nghiệp ngay từ lần ghé đầu tiên:
            giao diện sang trọng, nội dung rõ ràng và hành trình khám phá mạch lạc.
        </p>
    </article>
    <article class="collection-card">
        <span class="eyebrow">Tin cậy</span>
        <h3>Thống kê và quản lý đồng bộ</h3>
        <p>Hệ thống ghi nhận số lượng xe theo hãng, xe bán chạy và tổng lượng xe trong showroom theo thời gian thực.</p>
    </article>
    <article class="collection-card">
        <span class="eyebrow">Hiệu quả</span>
        <h3>Hỗ trợ đội ngũ vận hành</h3>
        <p>Thông tin cập nhật tập trung giúp nhân viên và quản trị viên phối hợp nhanh, chính xác và nhất quán.</p>
    </article>
</section>
