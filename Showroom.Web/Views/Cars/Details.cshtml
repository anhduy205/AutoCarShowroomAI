@model Showroom.Web.Models.CarDetailsViewModel

@{
    ViewData["Title"] = "Chi tiết xe";
}

<section class="dashboard-shell">
    <div class="page-heading">
        <div>
            <span class="eyebrow">Xe</span>
            <h1>Chi tiết xe</h1>
            <p>Xem thông tin chi tiết và ảnh minh hoạ (nếu có).</p>
        </div>
        <div class="page-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Quay lại</a>
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Sửa xe</a>
        </div>
    </div>

    <article class="panel-card">
        <div class="row g-4">
            <div class="col-lg-7">
                <h2 class="h4 mb-3">@Model.Name</h2>
                @{
                    var statusClass = Model.Status switch
                    {
                        CarStatusCatalog.InStock => "status-success",
                        CarStatusCatalog.Promotion => "status-warning",
                        CarStatusCatalog.Sold => "status-danger",
                        _ => "status-warning"
                    };
                }
                <div class="mb-3">
                    <span class="status-chip @statusClass">@Model.Status</span>
                </div>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Hãng</dt>
                    <dd class="col-sm-8">@Model.BrandName</dd>

                    <dt class="col-sm-4">Loại</dt>
                    <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(Model.Type) ? Model.Type : "-")</dd>

                    <dt class="col-sm-4">Năm</dt>
                    <dd class="col-sm-8">@(Model.Year is null ? "-" : Model.Year.Value.ToString())</dd>

                    <dt class="col-sm-4">Màu</dt>
                    <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(Model.Color) ? Model.Color : "-")</dd>

                    <dt class="col-sm-4">Giá</dt>
                    <dd class="col-sm-8">@Model.Price.ToString("N0") VNĐ</dd>

                    <dt class="col-sm-4">Tồn kho</dt>
                    <dd class="col-sm-8">@Model.StockQuantity</dd>

                    <dt class="col-sm-4">Ngày tạo</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <hr />
                    <h3 class="h5">Mô tả</h3>
                    <p class="mb-0">@Model.Description</p>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Specifications))
                {
                    <hr />
                    <h3 class="h5">Thông số kỹ thuật</h3>
                    <pre class="mb-0" style="white-space: pre-wrap;">@Model.Specifications</pre>
                }
            </div>

            <div class="col-lg-5">
                <h3 class="h5">Ảnh</h3>

                @if (Model.ImageUrls.Count == 0)
                {
                    <p class="text-muted mb-0">Chưa có ảnh cho xe này.</p>
                }
                else
                {
                    <div class="d-grid gap-3">
                        @foreach (var url in Model.ImageUrls)
                        {
                            <a href="@url" target="_blank" rel="noopener noreferrer">
                                <img src="@url" alt="Ảnh @Model.Name" class="img-fluid rounded" />
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </article>
</section>
